generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String     @id @default(cuid())
  fullName  String
  email     String     @unique
  password  String
  whatsapp  String?
  teacherCertification String?
  teacherAvailableTimes String?
  teacherAvailableTracks String?
  teacherWorkScope String?
  role      UserRole
  studyMode StudyMode
  canAccessFinance Boolean @default(false)
  canAccessSupervision Boolean @default(false)
  isActive  Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  circles   Circle[]   @relation("CircleTeacher")
  reports   Report[]
  students  Student[]
  zoomLinks ZoomLink[]
  compensationRule TeacherCompensationRule?
  teacherPayouts TeacherPayout[]
  teacherAttendances TeacherAttendance[]
  financeAuditLogs FinanceAuditLog[]
  trackResources TrackResource[]
  teacherRequests TeacherRequest[] @relation("TeacherRequestTeacher")
  reviewedTeacherRequests TeacherRequest[] @relation("TeacherRequestAdmin")
  notifications UserNotification[]
  createdSupervisionTasks SupervisionTask[] @relation("SupervisionTaskCreator")
  supervisionActions StudentFollowUpAction[] @relation("StudentFollowUpActor")
  teacherVisitReportsAsTeacher TeacherVisitReport[] @relation("TeacherVisitTeacher")
  teacherVisitReportsAsSupervisor TeacherVisitReport[] @relation("TeacherVisitSupervisor")
  educationConversationsAsTeacher EducationConversation[] @relation("EducationConversationTeacher")
  educationMessages EducationMessage[] @relation("EducationMessageUser")
}

model Student {
  id             String    @id @default(cuid())
  fullName       String
  studyMode      StudyMode
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  teacherId      String
  circleId       String?
  studentCode    String?   @unique
  parentWhatsapp String?
  parentEmail    String?
  detail         StudentDetail?
  financeAccount StudentFinanceAccount?
  payments       StudentPayment[]
  reports        Report[]
  teacherRequests TeacherRequest[]
  supervisionTasks SupervisionTask[]
  followUpActions StudentFollowUpAction[]
  incomingWhatsAppMessages WhatsAppIncomingMessage[]
  outgoingWhatsAppMessages WhatsAppOutgoingMessage[]
  educationConversations EducationConversation[]
  circle         Circle?   @relation(fields: [circleId], references: [id])
  teacher        User      @relation(fields: [teacherId], references: [id], onDelete: Cascade)
}

model ParentPortalCode {
  id        String   @id @default(cuid())
  phone     String
  code      String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([phone, createdAt])
}

model EducationConversation {
  id          String             @id @default(cuid())
  studentId   String
  teacherId   String?
  parentPhone String
  type        String             @default("TEACHER")
  status      String             @default("OPEN")
  lastMessageAt DateTime?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  student     Student            @relation(fields: [studentId], references: [id], onDelete: Cascade)
  teacher     User?              @relation("EducationConversationTeacher", fields: [teacherId], references: [id], onDelete: SetNull)
  messages    EducationMessage[]

  @@index([studentId, updatedAt])
  @@index([teacherId, updatedAt])
  @@index([parentPhone, updatedAt])
  @@unique([studentId, teacherId, type])
}

model EducationMessage {
  id             String                @id @default(cuid())
  conversationId String
  senderRole     String
  senderUserId   String?
  senderPhone    String?
  body           String?
  attachmentUrl  String?
  attachmentName String?
  attachmentType String?
  createdAt      DateTime              @default(now())
  readByParentAt DateTime?
  readByTeacherAt DateTime?
  readByAdminAt   DateTime?
  conversation   EducationConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderUser     User?                 @relation("EducationMessageUser", fields: [senderUserId], references: [id], onDelete: SetNull)

  @@index([conversationId, createdAt])
  @@index([senderUserId])
}

model StudentFinanceAccount {
  id             String   @id @default(cuid())
  studentId      String   @unique
  totalAmount    Decimal  @default(0) @db.Decimal(10, 2)
  discountAmount Decimal  @default(0) @db.Decimal(10, 2)
  currency       String   @default("USD")
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  student        Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

model StudentPayment {
  id            String   @id @default(cuid())
  studentId     String
  amount        Decimal  @db.Decimal(10, 2)
  currency      String   @default("USD")
  method        String?
  paidAt        DateTime @default(now())
  note          String?
  createdAt     DateTime @default(now())
  student       Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([paidAt])
}

model PlatformExpense {
  id            String   @id @default(cuid())
  title         String
  category      String
  amount        Decimal  @db.Decimal(10, 2)
  currency      String   @default("USD")
  expenseDate   DateTime @default(now())
  recurrence    String   @default("ONE_TIME")
  dueDay        Int?
  nextDueDate   DateTime?
  isActive      Boolean  @default(true)
  paymentMethod String?
  receiptUrl    String?
  note          String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([expenseDate])
  @@index([category])
}

model TeacherCompensationRule {
  id                   String   @id @default(cuid())
  teacherId            String   @unique
  monthlyAmount        Decimal  @default(0) @db.Decimal(10, 2)
  expectedMonthlyHours Decimal  @default(0) @db.Decimal(10, 2)
  expectedMonthlyWorkDays Decimal @default(20) @db.Decimal(10, 2)
  currency             String   @default("USD")
  notes                String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  teacher              User     @relation(fields: [teacherId], references: [id], onDelete: Cascade)
}

model TeacherPayout {
  id            String   @id @default(cuid())
  teacherId     String
  periodMonth   String
  amount        Decimal  @db.Decimal(10, 2)
  currency      String   @default("USD")
  paidAt        DateTime @default(now())
  method        String?
  note          String?
  createdAt     DateTime @default(now())
  teacher       User     @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@index([teacherId, periodMonth])
  @@index([paidAt])
}

model TeacherAttendance {
  id        String                  @id @default(cuid())
  teacherId String
  dateKey   String
  status    TeacherAttendanceStatus
  note      String?
  createdAt DateTime                @default(now())
  updatedAt DateTime                @updatedAt
  teacher   User                    @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@unique([teacherId, dateKey])
  @@index([dateKey])
}

model FinanceAuditLog {
  id        String   @id @default(cuid())
  actorId   String?
  action    String
  entity    String
  entityId  String?
  summary   String
  details   Json?
  createdAt DateTime @default(now())
  actor     User?    @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([actorId])
  @@index([entity])
}

model AppSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TeacherRequest {
  id         String                 @id @default(cuid())
  teacherId  String
  studentId  String?
  type       TeacherRequestType
  priority   TeacherRequestPriority @default(NORMAL)
  status     TeacherRequestStatus   @default(NEW)
  subject    String
  details    String
  adminNote  String?
  reviewedBy String?
  resolvedAt DateTime?
  createdAt  DateTime               @default(now())
  updatedAt  DateTime               @updatedAt
  teacher    User                   @relation("TeacherRequestTeacher", fields: [teacherId], references: [id], onDelete: Cascade)
  student    Student?               @relation(fields: [studentId], references: [id], onDelete: SetNull)
  reviewer   User?                  @relation("TeacherRequestAdmin", fields: [reviewedBy], references: [id], onDelete: SetNull)

  @@index([teacherId, status])
  @@index([status, createdAt])
  @@index([studentId])
}

model UserNotification {
  id        String               @id @default(cuid())
  userId     String
  type      UserNotificationType @default(GENERAL)
  title     String
  body      String
  link      String?
  isRead    Boolean              @default(false)
  readAt    DateTime?
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt
  user      User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead, createdAt])
}

model SupervisionTask {
  id          String                @id @default(cuid())
  studentId   String?
  createdById String?
  source      SupervisionTaskSource @default(AUTOMATIC)
  category    SupervisionTaskCategory
  title       String
  details     String
  status      SupervisionTaskStatus @default(NEW)
  triggerKey  String?
  assignedTo  String?
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt
  closedAt    DateTime?
  student     Student?              @relation(fields: [studentId], references: [id], onDelete: SetNull)
  creator     User?                 @relation("SupervisionTaskCreator", fields: [createdById], references: [id], onDelete: SetNull)
  actions     StudentFollowUpAction[]
  teacherVisitReports TeacherVisitReport[]

  @@index([status, source, createdAt])
  @@index([studentId, status])
  @@unique([triggerKey])
}

model StudentFollowUpAction {
  id                   String                 @id @default(cuid())
  studentId            String
  supervisionTaskId    String?
  actorId              String?
  actionType           StudentFollowUpActionType
  title                String
  details              String
  contactedParent      Boolean                @default(false)
  contactedTeacher     Boolean                @default(false)
  createdAt            DateTime               @default(now())
  student              Student                @relation(fields: [studentId], references: [id], onDelete: Cascade)
  supervisionTask      SupervisionTask?       @relation(fields: [supervisionTaskId], references: [id], onDelete: SetNull)
  actor                User?                  @relation("StudentFollowUpActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([studentId, createdAt])
  @@index([supervisionTaskId])
}

model TeacherVisitReport {
  id                  String          @id @default(cuid())
  visitNumber         Int             @unique @default(autoincrement())
  supervisorId        String
  teacherId           String
  taskId              String?
  visitDate           DateTime
  dayLabel            String
  visitType           TeacherVisitType
  trackLabel          String
  periodLabel         String
  overallEvaluation   String?
  finalRecommendation String?
  generalNotes        String?
  mainItems           Json
  generalItems        Json
  pdfPath             String?
  pdfGeneratedAt      DateTime?
  sentToTeacherAt     DateTime?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  supervisor          User            @relation("TeacherVisitSupervisor", fields: [supervisorId], references: [id], onDelete: Cascade)
  teacher             User            @relation("TeacherVisitTeacher", fields: [teacherId], references: [id], onDelete: Cascade)
  task                SupervisionTask? @relation(fields: [taskId], references: [id], onDelete: SetNull)

  @@index([teacherId, visitDate])
  @@index([supervisorId, createdAt])
  @@index([taskId])
}

model StudentDetail {
  id              String   @id @default(cuid())
  studentId       String   @unique
  source          String
  sourceStudentNo String?
  matchedName     String
  idImageUrl      String?
  birthDate       String?
  birthPlace      String?
  nationality     String?
  generalLevel    String?
  livingWith      String?
  grade           String?
  schoolName      String?
  fatherPhone     String?
  motherPhone     String?
  guardianPhone   String?
  fatherAlive     String?
  motherAlive     String?
  fatherEducation String?
  motherEducation String?
  hasIncome       String?
  monthlyIncome   String?
  homeLocation    String?
  gatheringArea   String?
  notes           String?
  rawData         Json
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  student         Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

model Circle {
  id        String    @id @default(cuid())
  name      String
  studyMode StudyMode
  zoomUrl   String?
  periodLabel String?
  startsAt  String?
  endsAt    String?
  teacherId String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  track     String?
  teacher   User?     @relation("CircleTeacher", fields: [teacherId], references: [id])
  students  Student[]
}

model TrackResource {
  id          String   @id @default(cuid())
  title       String
  description String?
  track       String?
  teacherId   String?
  resourceScope TrackResourceScope @default(TEACHER)
  fileUrl     String
  fileName    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  teacher     User?    @relation(fields: [teacherId], references: [id], onDelete: SetNull)

  @@index([teacherId])
}

model RegistrationRequest {
  id                 String             @id @default(cuid())
  studentName        String
  previousStudent    Boolean            @default(false)
  birthDate          DateTime?
  grade              String?
  gender             String?
  country            String?
  preferredPeriod    String?
  parentWhatsapp     String
  parentEmail        String?
  previousStudy      String?
  memorizedAmount    String?
  hasLearningIssues  Boolean            @default(false)
  learningIssuesNote String?
  hasDevice          Boolean            @default(false)
  requestedTracks    String?
  notes              String?
  status             RegistrationStatus @default(PENDING)
  createdStudentId   String?
  forwardedToSupervisionAt DateTime?
  supervisionStatus  SupervisionStatus  @default(PENDING)
  supervisionNote    String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  readingLevel       String?
  tajweedLevel       String?
  readGuidelines     Boolean            @default(false)
  audioUrl           String?
  audioFileName      String?
  nationality        String?
  fatherAlive        Boolean?
  motherAlive        Boolean?
  livingWith         String?
  fatherEducation    String?
  motherEducation    String?
  idImageUrl         String?
  idImageFileName    String?
  interviewDate      DateTime?
  interviewLink      String?
  interviewResult    String?
  interviewLevel     String?
  interviewDecision  String?
  incomingWhatsAppMessages WhatsAppIncomingMessage[]
  outgoingWhatsAppMessages WhatsAppOutgoingMessage[]
}

model WhatsAppIncomingMessage {
  id                    String                   @id @default(cuid())
  messageId             String?                  @unique
  channel               StudyMode
  fromNumber            String
  body                  String
  category              WhatsAppIncomingCategory @default(GENERAL)
  isRead                Boolean                  @default(false)
  raw                   Json?
  followUpStatus        WhatsAppFollowUpStatus   @default(NEW)
  supervisorNote        String?
  lastOutgoingMessageId String?
  studentId             String?
  registrationRequestId String?
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt
  student               Student?                 @relation(fields: [studentId], references: [id], onDelete: SetNull)
  registrationRequest   RegistrationRequest?     @relation(fields: [registrationRequestId], references: [id], onDelete: SetNull)
  lastOutgoingMessage   WhatsAppOutgoingMessage?  @relation(fields: [lastOutgoingMessageId], references: [id], onDelete: SetNull)

  @@index([channel, isRead, createdAt])
  @@index([fromNumber])
  @@index([studentId])
  @@index([registrationRequestId])
  @@index([lastOutgoingMessageId])
}

model WhatsAppOutgoingMessage {
  id                    String                   @id @default(cuid())
  messageId             String?
  channel               StudyMode
  toNumber              String
  body                  String
  category              WhatsAppIncomingCategory @default(GENERAL)
  studentId             String?
  registrationRequestId String?
  createdAt             DateTime                 @default(now())
  student               Student?                 @relation(fields: [studentId], references: [id], onDelete: SetNull)
  registrationRequest   RegistrationRequest?     @relation(fields: [registrationRequestId], references: [id], onDelete: SetNull)
  incomingReplies       WhatsAppIncomingMessage[]

  @@index([channel, toNumber, createdAt])
  @@index([studentId])
  @@index([registrationRequestId])
}

model Report {
  id                 String             @id @default(cuid())
  lessonName         String
  review             String?
  homework           String
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  studentId          String
  note               String?
  status             ReportStatus       @default(PRESENT)
  teacherId          String?
  pageFrom           Int?
  pageTo             Int?
  pagesCount         Int?
  sentToParent       Boolean            @default(false)
  nextHomework       String?
  lessonSurah        String?
  lessonMemorized    Boolean?
  lastFiveMemorized  Boolean?
  reviewSurah        String?
  reviewFrom         Int?
  reviewTo           Int?
  reviewPagesCount   Int?
  reviewMemorized    Boolean?
  nextLessonHomework String?
  nextReviewHomework String?
  parentSentAt       DateTime?
  parentSentChannel  ParentSentChannel?
  parentSentError    String?
  student            Student            @relation(fields: [studentId], references: [id], onDelete: Cascade)
  teacher            User?              @relation(fields: [teacherId], references: [id])
}

model ZoomLink {
  id        String    @id @default(cuid())
  title     String?
  url       String
  studyMode StudyMode
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  userId    String?
  user      User?     @relation(fields: [userId], references: [id])
}

enum UserRole {
  ADMIN
  TEACHER
}

enum StudyMode {
  REMOTE
  ONSITE
}

enum ReportStatus {
  PRESENT
  ABSENT
}

enum RegistrationStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum ParentSentChannel {
  EMAIL
  WHATSAPP
}

enum TeacherAttendanceStatus {
  PRESENT
  ABSENT
  EXCUSED
}

enum TrackResourceScope {
  TEACHER
  REGISTRATION
}

enum SupervisionStatus {
  PENDING
  UNDER_REVIEW
  PLACED
  ON_HOLD
}

enum WhatsAppIncomingCategory {
  GENERAL
  INTERVIEW_RESCHEDULE
  ABSENCE_EXCUSE
  COMPLAINT
  INQUIRY
  THANKS
  CONFIRMATION
  STRUGGLE_REPLY
}

enum WhatsAppFollowUpStatus {
  NEW
  IN_REVIEW
  REPLIED
  CLOSED
  ESCALATED
}

enum TeacherRequestType {
  TEST_REQUEST
  STRUGGLING_STUDENT
  SPECIAL_CASE
  GENERAL
}

enum TeacherRequestStatus {
  NEW
  IN_REVIEW
  RESOLVED
  REJECTED
}

enum TeacherRequestPriority {
  NORMAL
  HIGH
  URGENT
}

enum UserNotificationType {
  GENERAL
  REQUEST_UPDATED
  STUDENT_ASSIGNED
  STUDENT_MOVED
}

enum SupervisionTaskSource {
  AUTOMATIC
  TEACHER
  ADMIN
}

enum SupervisionTaskCategory {
  MEMORIZATION_STREAK
  ABSENCE_STREAK
  TEACHER_REQUEST
  TEACHER_VISIT
  GENERAL_SUPERVISION
}

enum SupervisionTaskStatus {
  NEW
  IN_PROGRESS
  WAITING
  DONE
}

enum StudentFollowUpActionType {
  SUPERVISION_NOTE
  PARENT_CONTACT
  TEACHER_CONTACT
  CLASS_VISIT
  TEACHER_VISIT
  GENERAL_ACTION
}

enum TeacherVisitType {
  FIELD
  SECRET
}
