generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  TEACHER
}

enum StudyMode {
  REMOTE
  ONSITE
}

enum ReportStatus {
  PRESENT
  ABSENT
}

model User {
  id         String     @id @default(cuid())
  fullName   String
  email      String     @unique
  password   String
  role       UserRole
  studyMode  StudyMode
  isActive   Boolean    @default(true)
  students   Student[]
  zoomLinks  ZoomLink[]
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
}

model Student {
  id         String      @id @default(cuid())
  fullName   String
  teacherId  String
  studyMode  StudyMode
  isActive   Boolean     @default(true)
  teacher    User        @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  reports    Report[]
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
}

model Report {
  id          String       @id @default(cuid())
  studentId   String
  lessonName  String
  review      String?
  homework    String
  note        String?
  status      ReportStatus @default(PRESENT)
  student     Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model ZoomLink {
  id         String     @id @default(cuid())
  title      String?
  url        String
  studyMode  StudyMode
  userId     String?
  user       User?      @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
}