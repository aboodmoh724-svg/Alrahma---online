generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String     @id @default(cuid())
  fullName  String
  email     String     @unique
  password  String
  role      UserRole
  studyMode StudyMode
  isActive  Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  circles   Circle[]   @relation("CircleTeacher")
  reports   Report[]
  students  Student[]
  zoomLinks ZoomLink[]
}

model Student {
  id             String    @id @default(cuid())
  fullName       String
  studyMode      StudyMode
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  teacherId      String
  circleId       String?
  studentCode    String?   @unique
  parentWhatsapp String?
  parentEmail    String?
  detail         StudentDetail?
  financeAccount StudentFinanceAccount?
  payments       StudentPayment[]
  reports        Report[]
  circle         Circle?   @relation(fields: [circleId], references: [id])
  teacher        User      @relation(fields: [teacherId], references: [id], onDelete: Cascade)
}

model StudentFinanceAccount {
  id             String   @id @default(cuid())
  studentId      String   @unique
  totalAmount    Decimal  @default(0) @db.Decimal(10, 2)
  discountAmount Decimal  @default(0) @db.Decimal(10, 2)
  currency       String   @default("USD")
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  student        Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

model StudentPayment {
  id            String   @id @default(cuid())
  studentId     String
  amount        Decimal  @db.Decimal(10, 2)
  currency      String   @default("USD")
  method        String?
  paidAt        DateTime @default(now())
  note          String?
  createdAt     DateTime @default(now())
  student       Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([paidAt])
}

model PlatformExpense {
  id            String   @id @default(cuid())
  title         String
  category      String
  amount        Decimal  @db.Decimal(10, 2)
  currency      String   @default("USD")
  expenseDate   DateTime @default(now())
  paymentMethod String?
  receiptUrl    String?
  note          String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([expenseDate])
  @@index([category])
}

model StudentDetail {
  id              String   @id @default(cuid())
  studentId       String   @unique
  source          String
  sourceStudentNo String?
  matchedName     String
  idImageUrl      String?
  birthDate       String?
  birthPlace      String?
  nationality     String?
  generalLevel    String?
  livingWith      String?
  grade           String?
  schoolName      String?
  fatherPhone     String?
  motherPhone     String?
  guardianPhone   String?
  fatherAlive     String?
  motherAlive     String?
  fatherEducation String?
  motherEducation String?
  hasIncome       String?
  monthlyIncome   String?
  homeLocation    String?
  gatheringArea   String?
  notes           String?
  rawData         Json
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  student         Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

model Circle {
  id        String    @id @default(cuid())
  name      String
  studyMode StudyMode
  zoomUrl   String?
  teacherId String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  track     String?
  teacher   User?     @relation("CircleTeacher", fields: [teacherId], references: [id])
  students  Student[]
}

model TrackResource {
  id          String   @id @default(cuid())
  title       String
  description String?
  track       String?
  fileUrl     String
  fileName    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model RegistrationRequest {
  id                 String             @id @default(cuid())
  studentName        String
  previousStudent    Boolean            @default(false)
  birthDate          DateTime?
  grade              String?
  gender             String?
  country            String?
  preferredPeriod    String?
  parentWhatsapp     String
  parentEmail        String?
  previousStudy      String?
  memorizedAmount    String?
  hasLearningIssues  Boolean            @default(false)
  learningIssuesNote String?
  hasDevice          Boolean            @default(false)
  requestedTracks    String?
  notes              String?
  status             RegistrationStatus @default(PENDING)
  createdStudentId   String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  readingLevel       String?
  tajweedLevel       String?
  readGuidelines     Boolean            @default(false)
  audioUrl           String?
  audioFileName      String?
  nationality        String?
  fatherAlive        Boolean?
  motherAlive        Boolean?
  livingWith         String?
  fatherEducation    String?
  motherEducation    String?
  idImageUrl         String?
  idImageFileName    String?
}

model Report {
  id                 String             @id @default(cuid())
  lessonName         String
  review             String?
  homework           String
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  studentId          String
  note               String?
  status             ReportStatus       @default(PRESENT)
  teacherId          String?
  pageFrom           Int?
  pageTo             Int?
  pagesCount         Int?
  sentToParent       Boolean            @default(false)
  nextHomework       String?
  lessonSurah        String?
  lessonMemorized    Boolean?
  lastFiveMemorized  Boolean?
  reviewSurah        String?
  reviewFrom         Int?
  reviewTo           Int?
  reviewPagesCount   Int?
  reviewMemorized    Boolean?
  nextLessonHomework String?
  nextReviewHomework String?
  parentSentAt       DateTime?
  parentSentChannel  ParentSentChannel?
  parentSentError    String?
  student            Student            @relation(fields: [studentId], references: [id], onDelete: Cascade)
  teacher            User?              @relation(fields: [teacherId], references: [id])
}

model ZoomLink {
  id        String    @id @default(cuid())
  title     String?
  url       String
  studyMode StudyMode
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  userId    String?
  user      User?     @relation(fields: [userId], references: [id])
}

enum UserRole {
  ADMIN
  TEACHER
}

enum StudyMode {
  REMOTE
  ONSITE
}

enum ReportStatus {
  PRESENT
  ABSENT
}

enum RegistrationStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum ParentSentChannel {
  EMAIL
  WHATSAPP
}
