DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

# Supabase Storage is used for student audio, identity files, and uploaded resources.
SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="YOUR_SERVICE_ROLE_KEY"
SUPABASE_STORAGE_BUCKET="alrahma-uploads"

# Optional: used for registration confirmations and daily report emails.
BREVO_API_KEY="YOUR_BREVO_API_KEY"
EMAIL_FROM="منصة الرحمة <reports@your-domain.com>"

# Optional fallback if Brevo is not configured.
RESEND_API_KEY="YOUR_RESEND_API_KEY"

# Optional: WhatsApp Cloud API / Business Platform for onsite attendance messages.
WHATSAPP_TOKEN="YOUR_PERMANENT_OR_LONG_LIVED_TOKEN"
WHATSAPP_PHONE_NUMBER_ID="YOUR_PHONE_NUMBER_ID"
WHATSAPP_BUSINESS_ACCOUNT_ID="YOUR_WABA_ID"
WHATSAPP_PRESENT_TEMPLATE_NAME="attendance_present"
WHATSAPP_PRESENT_TEMPLATE_LANG="ar"
WHATSAPP_ABSENCE_TEMPLATE_NAME="attendance_absent"
WHATSAPP_ABSENCE_TEMPLATE_LANG="ar"

# Optional: Make scenario webhook. If set, attendance messages are sent to Make first.
MAKE_ATTENDANCE_WEBHOOK_URL="https://hook.eu2.make.com/YOUR_WEBHOOK_ID"
MAKE_ATTENDANCE_WEBHOOK_SECRET="OPTIONAL_SHARED_SECRET"
