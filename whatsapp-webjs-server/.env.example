PORT=3333

# Optional. If set, every request to /send-message must include:
# Authorization: Bearer your-secret-token
API_TOKEN=

# Optional. Useful if you want to allow only your website origin.
# Example: https://alrahma-reports.vercel.app
ALLOWED_ORIGIN=*

# Incoming messages can be forwarded to the main app.
WHATSAPP_CHANNEL=REMOTE
APP_INCOMING_WHATSAPP_WEBHOOK_URL=http://127.0.0.1:3005/api/whatsapp/incoming
APP_INCOMING_WHATSAPP_WEBHOOK_TOKEN=

# Optional puppeteer executable path for Linux VPS if Chromium is installed manually.
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium-browser
